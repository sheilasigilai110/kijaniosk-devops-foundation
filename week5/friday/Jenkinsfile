pipeline {
    agent {
        docker {
            image 'node:18.16.0-alpine'
            args '-u root:root -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        APP_NAME   = "kijanikiosk-payments"
        NEXUS_URL  = "http://172.17.0.1:8081"
        NEXUS_REPO = "npm-hosted"
    }

    stages {

        stage('Lint') {
            steps {
                dir('week5/friday/app') {
                    sh 'npm install'
                    sh 'npm run lint'
                }
            }
        }

        stage('Build') {
            steps {
                dir('week5/friday/app') {
                    sh 'npm run build'
                }
            }
        }

        stage('Verify') {
            steps {
                dir('week5/friday/app') {
                    sh 'npm test'
                }
            }
        }

        stage('Security Audit') {
            steps {
                dir('week5/friday/app') {
                    sh 'npm audit --audit-level=high'
                }
            }
        }

        stage('Prepare') {
            steps {
                sh '''
                    apk add --no-cache git
                    git config --global --add safe.directory $(pwd)
                '''
            }
        }

        stage('Version') {
            steps {
                script {
                    def gitSha = sh(
                        script: "git rev-parse --short HEAD",
                        returnStdout: true
                    ).trim()

                    echo "DEBUG: gitSha = '${gitSha}'"

                    if (!gitSha) {
                        error "gitSha is empty! Git command failed."
                    }

                    env.VERSION = "1.0.0-${gitSha}"
                    echo "Version set to ${env.VERSION}"
                }

                dir('week5/friday/app') {
                    sh "npm version ${env.VERSION} --no-git-tag-version --allow-same-version"
                }
            }
        }

        stage('Archive') {
            steps {
                dir('week5/friday/app') {
                    archiveArtifacts artifacts: '**/*', fingerprint: true
                }
            }
        }

        stage('Publish') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-creds',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {
                    dir('week5/friday/app') {
                        sh '''
                            set -e

                            REGISTRY="http://172.17.0.1:8081/repository/npm-hosted/"

                            AUTH=$(echo -n "$NEXUS_USER:$NEXUS_PASS" | base64)

                            echo "registry=$REGISTRY" > .npmrc
                            echo "_auth=$AUTH" >> .npmrc
                            echo "email=ci@example.com" >> .npmrc
                            echo "always-auth=true" >> .npmrc

                            npm publish

                            rm -f .npmrc
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }

        success {
            echo "SUCCESS: Artifact published to Nexus at ${NEXUS_URL}"
        }

        failure {
            echo "FAILURE: Pipeline failed. Investigate logs."
        }

        changed {
            echo "NOTICE: Build status changed."
        }
    }
}
